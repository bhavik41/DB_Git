generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  githubId  String?   @unique
  password  String? // Optional for OAuth users
  projects  Project[]
  createdAt DateTime  @default(now())

  @@index([username])       // M5: fast username lookup for auth
  @@index([email])          // M5: fast email dedup
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  targetDbUrl String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  commits     Commit[]
  branches    Branch[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])         // M5: list all projects for a user efficiently
  @@index([name])           // M5: project lookup by name (already unique but explicit for query planner)
  @@index([updatedAt])      // M5: sort by last activity
}

model Branch {
  id           Int      @id @default(autoincrement())
  name         String
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id])
  headCommitId String?
  commits      Commit[]
  createdAt    DateTime @default(now())

  @@unique([projectId, name])
  @@index([projectId])      // M5: list branches per project
  @@index([headCommitId])   // M5: fast branch-head resolution during checkout/rollback
}

model Commit {
  id        String   @id @default(uuid())
  message   String
  author    String
  createdAt DateTime @default(now())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  snapshot Json // Full Schema Snapshot
  diff     Json?

  prevCommitId String?
  prevCommit   Commit?  @relation("CommitHistory", fields: [prevCommitId], references: [id])
  nextCommits  Commit[] @relation("CommitHistory")

  // M5: Performance indexes for commit history, diff retrieval, and version lookup
  @@index([projectId, branchId, createdAt(sort: Desc)])  // history query: project+branch ordered by time
  @@index([projectId, createdAt(sort: Desc)])            // cross-branch history / log
  @@index([prevCommitId])                                // version graph traversal (parent pointer)
  @@index([author])                                      // filter commits by author
  @@index([branchId, createdAt(sort: Desc)])             // branch-scoped log
}
