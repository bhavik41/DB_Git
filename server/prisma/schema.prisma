generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  githubId  String?   @unique
  password  String?
  projects  Project[]
  createdAt DateTime  @default(now())

  @@index([username])
  @@index([email])
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  targetDbUrl String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  commits     Commit[]
  branches    Branch[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([name])
  @@index([updatedAt])
}

model Branch {
  id           Int      @id @default(autoincrement())
  name         String
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id])
  headCommitId String?
  headCommit   Commit?  @relation("BranchHead", fields: [headCommitId], references: [id])
  commits      Commit[] @relation("BranchCommits")
  createdAt    DateTime @default(now())

  @@unique([projectId, name])
  @@index([projectId])
  @@index([headCommitId])
}

model Commit {
  id        String   @id @default(uuid())
  message   String
  author    String
  createdAt DateTime @default(now())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  branchId  Int?
  branch    Branch?  @relation("BranchCommits", fields: [branchId], references: [id])
  branchHead Branch[] @relation("BranchHead")

  snapshot Json
  diff     Json?
  dataDump String? @db.Text

  prevCommitId String?
  prevCommit   Commit?  @relation("CommitHistory", fields: [prevCommitId], references: [id])
  nextCommits  Commit[] @relation("CommitHistory")

  @@index([projectId, branchId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([prevCommitId])
  @@index([author])
  @@index([branchId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// Member 6: Concurrency Control Tables
// ─────────────────────────────────────────────────────────────────────────────

/// Tracks operations currently in-flight.
/// Written at the START of an atomic operation, deleted at the END.
/// Any record surviving a server restart = orphaned operation → recoveryService cleans it.
model CommitInProgress {
  id          String   @id @default(uuid())
  projectName String
  branchName  String
  author      String
  pid         Int      // OS process ID of the server handling this operation
  startedAt   DateTime @default(now())

  @@index([projectName, branchName])  // fast lookup during lock contention checks
  @@index([startedAt])                // stale detection by age
  @@index([pid])                      // process-alive checks during recovery
}

/// Permanent audit trail of all failed operations.
/// Written when a commit/rollback/checkout crashes or is force-cleaned.
/// Never deleted — provides forensic history for debugging.
model FailureLog {
  id          String   @id @default(uuid())
  operation   String   // 'commit' | 'rollback' | 'checkout' | 'handler_crash'
  projectName String
  branchName  String?
  author      String?
  error       String   // error message
  context     Json?    // extra debug info (body, stack, etc.)
  occurredAt  DateTime @default(now())

  @@index([projectName])
  @@index([occurredAt(sort: Desc)])
  @@index([operation])
}
